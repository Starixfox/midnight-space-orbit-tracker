        <div class="detail-cell-label">Orbit Type</div>
        <div class="detail-cell-value">${sat.orbitType}</div>
      </div>
    </div>
    <div class="detail-desc">${sat.description}</div>
    <a class="detail-link" href="https://www.space-track.org/basicspacedata/query/class/gp/NORAD_CAT_ID/${sat.noradId}" target="_blank" rel="noopener">
      ↗ View on Space-Track.org
    </a>
  `;
}

// ═══════════════════════════════════════════════════════════════════
// SIDEBAR LIST
// ═══════════════════════════════════════════════════════════════════
function getFilteredSats() {
  const search = document.getElementById('search-input').value.toLowerCase().trim();
  return TLE_DATA.filter(sat => {
    if (!filters.types.has(sat.objectType)) return false;
    if (!filters.orbits.has(sat.orbitType)) return false;
    if (filters.region === 'saudi' && !sat.isSaudi) return false;
    if (filters.region === 'arab' && !sat.isArab) return false;
    if (filters.region === 'gcc' && !sat.isGCC) return false;
    if (filters.region === 'global' && (sat.isArab || sat.isGCC)) return false;
    if (search && !sat.name.toLowerCase().includes(search) && !sat.noradId.includes(search)) return false;
    return true;
  });
}

function getTypeIcon(sat) {
  if (sat.objectType === 'debris') return '🗑️';
  if (sat.objectType === 'rocket_body') return '🚀';
  if (sat.objectType === 'unknown') return '❓';
  return '🛰️';
}

function renderSatList() {
  const list = document.getElementById('sat-list');
  const sats = getFilteredSats();

  list.innerHTML = sats.map(sat => `
    <div class="sat-item ${selectedId === sat.noradId ? 'selected' + (sat.isSaudi ? ' saudi-sel' : '') : ''}"
         data-norad="${sat.noradId}"
         onclick="selectSatellite('${sat.noradId}', true)">
      <span class="sat-icon">${getTypeIcon(sat)}</span>
      <div class="sat-info">
        <div class="sat-name ${sat.isSaudi ? 'saudi-name' : ''}">${sat.name}</div>
        <div class="sat-meta">
          <span class="badge badge-${sat.orbitType.toLowerCase()}">${sat.orbitType}</span>
          <span class="badge ${sat.objectType === 'debris' ? 'badge-debris' : sat.objectType === 'rocket_body' ? 'badge-rocket' : 'badge-payload'}">${sat.objectType.replace('_',' ')}</span>
          ${sat.isSaudi ? '<span class="saudi-flag">🇸🇦</span>' : ''}
        </div>
      </div>
    </div>
  `).join('');

  // Show/hide markers based on filters
  if (viewer) {
    const filteredIds = new Set(sats.map(s => s.noradId));
    Object.entries(satEntities).forEach(([id, entity]) => {
      entity.show = filteredIds.has(id);
    });
  }
}

// ═══════════════════════════════════════════════════════════════════
// FILTER CONTROLS
// ═══════════════════════════════════════════════════════════════════
function toggleFilter(category, value, el) {
  if (category === 'type') {
    if (filters.types.has(value)) {
      if (filters.types.size > 1) { filters.types.delete(value); el.classList.remove('active'); }
    } else {
      filters.types.add(value); el.classList.add('active');
    }
  } else if (category === 'orbit') {
    if (filters.orbits.has(value)) {
      if (filters.orbits.size > 1) { filters.orbits.delete(value); el.classList.remove('active'); }
    } else {
      filters.orbits.add(value); el.classList.add('active');
    }
  }
  applyFilters();
}

function setRegion(value, el) {
  filters.region = value;
  document.querySelectorAll('#region-filters .pill').forEach(p => p.classList.remove('active','green-pill'));
  el.classList.add('active');
  if (value === 'all') el.classList.add('green-pill');
  applyFilters();
}

function applyFilters() {
  renderSatList();
}

function toggleHighlight() {
  highlightSaudi = !highlightSaudi;
  document.getElementById('highlight-track').classList.toggle('on', highlightSaudi);
  updateSatSizes();
}

