<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Midnight Space — Orbital Tracker</title>

  <!-- NOTE: Replace the Cesium Ion token below with your own free token from cesium.com/ion -->
  <!-- CesiumJS for 3D globe -->
  <script src="https://cesium.com/downloads/cesiumjs/releases/1.114/Build/Cesium/Cesium.js"></script>
  <link href="https://cesium.com/downloads/cesiumjs/releases/1.114/Build/Cesium/Widgets/widgets.css" rel="stylesheet" />

  <!-- Satellite.js for orbital mechanics -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/satellite.js/4.0.0/satellite.min.js"></script>

  <style>
    /* ─── Reset & Base ─────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg-primary:   #0a0a0f;
      --bg-sidebar:   #0f0f1a;
      --bg-card:      #13131f;
      --bg-card2:     #1a1a2e;
      --border:       #1e1e35;
      --accent-green: #00ff88;
      --accent-blue:  #4a9eff;
      --accent-gold:  #ffd700;
      --accent-red:   #ff4455;
      --accent-orange:#ff8c42;
      --text-primary: #e8e8f0;
      --text-muted:   #6b6b8a;
      --text-dim:     #3a3a55;
      --sidebar-w:    300px;
      --navbar-h:     52px;
      --bottom-h:     185px;
      --font: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
    }

    html, body {
      height: 100%;
      overflow: hidden;
      background: var(--bg-primary);
      color: var(--text-primary);
      font-family: var(--font);
      font-size: 13px;
    }

    /* ─── Layout Shell ─────────────────────────────────── */
    #app {
      display: grid;
      grid-template-rows: var(--navbar-h) 1fr var(--bottom-h) 22px;
      grid-template-columns: var(--sidebar-w) 1fr;
      grid-template-areas:
        "nav    nav"
        "side   globe"
        "bottom bottom"
        "foot   foot";
      height: 100vh;
      width: 100vw;
    }

    /* ─── Navbar ───────────────────────────────────────── */
    #navbar {
      grid-area: nav;
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 0 16px;
      background: var(--bg-card);
      border-bottom: 1px solid var(--border);
      z-index: 100;
      flex-shrink: 0;
    }

    #hamburger {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      flex-direction: column;
      gap: 4px;
      padding: 4px;
    }
    #hamburger span {
      display: block;
      width: 20px;
      height: 2px;
      background: var(--text-primary);
      border-radius: 2px;
      transition: all 0.2s;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
    }
    .nav-logo svg { flex-shrink: 0; }
    .nav-logo-text {
      font-size: 14px;
      font-weight: 700;
      color: var(--accent-green);
      letter-spacing: 0.05em;
      white-space: nowrap;
    }

    #stat-strip {
      display: flex;
      gap: 10px;
      margin-left: auto;
      align-items: center;
      flex-wrap: nowrap;
    }
    .stat-item {
      display: flex;
      align-items: center;
      gap: 5px;
      background: var(--bg-sidebar);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 3px 8px;
      white-space: nowrap;
    }
    .stat-label { color: var(--text-muted); font-size: 11px; }
    .stat-value { color: var(--accent-blue); font-weight: 700; font-size: 12px; }
    .stat-value.green { color: var(--accent-green); }

    #utc-clock {
      background: var(--bg-sidebar);
      border: 1px solid var(--accent-green);
      border-radius: 6px;
      padding: 3px 10px;
      color: var(--accent-green);
      font-size: 12px;
      font-weight: 600;
      font-variant-numeric: tabular-nums;
      letter-spacing: 0.06em;
      white-space: nowrap;
    }

    /* ─── Sidebar ──────────────────────────────────────── */
    #sidebar {
      grid-area: side;
      background: var(--bg-sidebar);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      overflow: hidden;
      z-index: 50;
    }

    .sidebar-tabs {
      display: flex;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }
    .sidebar-tab {
      flex: 1;
      padding: 9px 0;
      background: none;
      border: none;
      cursor: pointer;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--text-muted);
      transition: all 0.15s;
      border-bottom: 2px solid transparent;
    }
    .sidebar-tab.active {
      color: var(--accent-blue);
      border-bottom-color: var(--accent-blue);
    }
    .sidebar-tab.saudi-tab.active {
      color: var(--accent-green);
      border-bottom-color: var(--accent-green);
    }

    /* Filter panel */
    #filter-panel {
      padding: 12px;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }

    .filter-section { margin-bottom: 10px; }
    .filter-title {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 6px;
    }

    .pill-group { display: flex; flex-wrap: wrap; gap: 5px; }
    .pill {
      padding: 3px 9px;
      border-radius: 20px;
      border: 1px solid var(--border);
      background: var(--bg-card);
      color: var(--text-muted);
      font-size: 11px;
      cursor: pointer;
      transition: all 0.15s;
      user-select: none;
    }
    .pill.active {
      background: rgba(74,158,255,0.15);
      border-color: var(--accent-blue);
      color: var(--accent-blue);
    }
    .pill.active.green-pill {
      background: rgba(0,255,136,0.12);
      border-color: var(--accent-green);
      color: var(--accent-green);
    }

    #search-input {
      width: 100%;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 7px 10px;
      color: var(--text-primary);
      font-size: 12px;
      outline: none;
      transition: border-color 0.15s;
    }
    #search-input:focus { border-color: var(--accent-blue); }
    #search-input::placeholder { color: var(--text-dim); }

    .highlight-toggle {
      display: flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
      margin-top: 8px;
    }
    .toggle-track {
      width: 34px;
      height: 18px;
      background: var(--bg-card2);
      border: 1px solid var(--border);
      border-radius: 9px;
      position: relative;
      transition: background 0.2s;
      flex-shrink: 0;
    }
    .toggle-track.on {
      background: rgba(0,255,136,0.25);
      border-color: var(--accent-green);
    }
    .toggle-knob {
      position: absolute;
      top: 2px;
      left: 2px;
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: var(--text-muted);
      transition: all 0.2s;
    }
    .toggle-track.on .toggle-knob {
      left: 18px;
      background: var(--accent-green);
    }
    .toggle-label { font-size: 11px; color: var(--text-muted); }

    /* Satellite list */
    #sat-list-container {
      flex: 1;
      overflow-y: auto;
      padding: 6px;
    }
    #sat-list-container::-webkit-scrollbar { width: 4px; }
    #sat-list-container::-webkit-scrollbar-track { background: transparent; }
    #sat-list-container::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

    .sat-item {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 7px 9px;
      border-radius: 7px;
      cursor: pointer;
      transition: background 0.12s;
      border: 1px solid transparent;
      margin-bottom: 2px;
    }
    .sat-item:hover { background: var(--bg-card2); }
    .sat-item.selected {
      background: rgba(74,158,255,0.1);
      border-color: rgba(74,158,255,0.25);
    }
    .sat-item.selected.saudi-sel {
      background: rgba(0,255,136,0.08);
      border-color: rgba(0,255,136,0.2);
    }

    .sat-icon { font-size: 14px; flex-shrink: 0; }
    .sat-info { flex: 1; min-width: 0; }
    .sat-name {
      font-size: 12px;
      font-weight: 600;
      color: var(--text-primary);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .sat-name.saudi-name { color: var(--accent-green); }
    .sat-meta { display: flex; align-items: center; gap: 4px; margin-top: 2px; }

    .badge {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.06em;
      padding: 1px 5px;
      border-radius: 4px;
      text-transform: uppercase;
    }
    .badge-leo { background: rgba(74,158,255,0.2); color: var(--accent-blue); }
    .badge-geo { background: rgba(255,215,0,0.15); color: var(--accent-gold); }
    .badge-meo { background: rgba(0,255,136,0.15); color: var(--accent-green); }
    .badge-heo { background: rgba(255,140,66,0.2); color: var(--accent-orange); }
    .badge-debris { background: rgba(255,68,85,0.15); color: var(--accent-red); }
    .badge-rocket { background: rgba(255,140,66,0.15); color: var(--accent-orange); }
    .badge-payload { background: rgba(74,158,255,0.15); color: var(--accent-blue); }

    .saudi-flag { font-size: 12px; }

    /* Saudi Assets Panel */
    #saudi-panel {
      padding: 14px 12px;
      overflow-y: auto;
      flex: 1;
    }
    #saudi-panel::-webkit-scrollbar { width: 4px; }
    #saudi-panel::-webkit-scrollbar-thumb { background: var(--border); }

    .saudi-summary {
      background: var(--bg-card);
      border: 1px solid rgba(0,255,136,0.2);
      border-radius: 10px;
      padding: 14px;
      margin-bottom: 12px;
    }
    .saudi-summary-title {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent-green);
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .saudi-stat-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }
    .saudi-stat-box {
      background: var(--bg-card2);
      border-radius: 7px;
      padding: 10px;
      text-align: center;
    }
    .saudi-stat-box .num {
      font-size: 22px;
      font-weight: 800;
      color: var(--accent-green);
      display: block;
    }
    .saudi-stat-box .lbl {
      font-size: 10px;
      color: var(--text-muted);
      margin-top: 2px;
    }
    .saudi-desc {
      font-size: 11px;
      color: var(--text-muted);
      line-height: 1.6;
      padding: 10px 12px;
      background: var(--bg-card2);
      border-radius: 7px;
      border-left: 2px solid var(--accent-green);
      margin-bottom: 12px;
    }

    /* ─── Globe ────────────────────────────────────────── */
    #globe-container {
      grid-area: globe;
      position: relative;
      overflow: hidden;
    }

    #cesiumContainer {
      width: 100%;
      height: 100%;
    }

    /* Hide most Cesium UI */
    .cesium-viewer-toolbar,
    .cesium-viewer-animationContainer,
    .cesium-viewer-timelineContainer,
    .cesium-viewer-bottom,
    .cesium-viewer-fullscreenContainer,
    .cesium-viewer-vrContainer,
    .cesium-infoBox,
    .cesium-selection-wrapper {
      display: none !important;
    }

    #globe-controls {
      position: absolute;
      top: 12px;
      right: 12px;
      display: flex;
      flex-direction: column;
      gap: 6px;
      z-index: 10;
    }
    .globe-btn {
      width: 34px;
      height: 34px;
      background: rgba(13,13,30,0.85);
      border: 1px solid var(--border);
      border-radius: 7px;
      color: var(--text-primary);
      font-size: 16px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.15s;
      backdrop-filter: blur(6px);
    }
    .globe-btn:hover {
      border-color: var(--accent-blue);
      color: var(--accent-blue);
    }

    #refresh-indicator {
      position: absolute;
      bottom: 12px;
      right: 12px;
      font-size: 10px;
      color: var(--text-muted);
      background: rgba(13,13,30,0.8);
      padding: 4px 8px;
      border-radius: 5px;
      border: 1px solid var(--border);
      backdrop-filter: blur(4px);
      z-index: 10;
    }
    #refresh-indicator.updating {
      color: var(--accent-green);
      border-color: rgba(0,255,136,0.3);
    }

    #tooltip {
      position: absolute;
      background: rgba(13,13,30,0.95);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 6px 10px;
      font-size: 11px;
      color: var(--text-primary);
      pointer-events: none;
      z-index: 200;
      display: none;
      backdrop-filter: blur(8px);
      white-space: nowrap;
    }

    #cesium-fallback {
      display: none;
      position: absolute;
      inset: 0;
      background: var(--bg-card);
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 12px;
      text-align: center;
      padding: 40px;
    }
    #cesium-fallback h2 { color: var(--accent-red); font-size: 18px; }
    #cesium-fallback p { color: var(--text-muted); max-width: 400px; line-height: 1.6; }

    /* ─── Bottom Panel ─────────────────────────────────── */
    #bottom-panel {
      grid-area: bottom;
      background: var(--bg-card);
      border-top: 1px solid var(--border);
      overflow: hidden;
      display: flex;
      align-items: stretch;
    }

    #detail-empty {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      gap: 10px;
      color: var(--text-muted);
      font-size: 13px;
    }
    #detail-empty svg { opacity: 0.3; }

    #detail-card {
      display: none;
      width: 100%;
      padding: 14px 20px;
      overflow-x: auto;
    }

    .detail-header {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 12px;
    }
    .detail-name {
      font-size: 16px;
      font-weight: 800;
      color: var(--text-primary);
    }
    .detail-name.saudi { color: var(--accent-green); }
    .detail-norad { font-size: 11px; color: var(--text-muted); }

    .detail-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 8px;
    }
    .detail-cell {
      background: var(--bg-sidebar);
      border: 1px solid var(--border);
      border-radius: 7px;
      padding: 8px 10px;
    }
    .detail-cell-label {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 4px;
    }
    .detail-cell-value {
      font-size: 13px;
      font-weight: 600;
      color: var(--text-primary);
    }
    .detail-cell-value.green { color: var(--accent-green); }
    .detail-cell-value.blue { color: var(--accent-blue); }

    .detail-link {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      margin-top: 10px;
      font-size: 11px;
      color: var(--accent-blue);
      text-decoration: none;
      border: 1px solid rgba(74,158,255,0.3);
      border-radius: 5px;
      padding: 4px 10px;
      transition: all 0.15s;
    }
    .detail-link:hover {
      background: rgba(74,158,255,0.1);
      border-color: var(--accent-blue);
    }

    .detail-desc {
      font-size: 11px;
      color: var(--text-muted);
      line-height: 1.5;
      margin-top: 8px;
      max-width: 600px;
    }

    /* ─── Footer ───────────────────────────────────────── */
    #footer {
      height: 22px;
      background: rgba(10,10,15,0.98);
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      font-size: 10px;
      color: var(--text-dim);
      padding: 0 16px;
      overflow: hidden;
      white-space: nowrap;
    }
    #footer a { color: var(--text-dim); text-decoration: none; }
    #footer a:hover { color: var(--accent-blue); }
    .footer-sep { color: var(--text-dim); }

    /* ─── Mobile ───────────────────────────────────────── */
    @media (max-width: 768px) {
      :root {
        --sidebar-w: 0px;
        --bottom-h: 0px;
        --navbar-h: 48px;
      }
      #app {
        grid-template-columns: 1fr;
        grid-template-rows: var(--navbar-h) 1fr;
        grid-template-areas: "nav" "globe";
      }
      #sidebar {
        position: fixed;
        top: var(--navbar-h);
        left: 0;
        bottom: 0;
        width: 280px;
        transform: translateX(-100%);
        transition: transform 0.25s ease;
        z-index: 200;
      }
      #sidebar.open { transform: translateX(0); }
      #hamburger { display: flex; }
      #bottom-panel {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        height: 185px;
        transform: translateY(100%);
        transition: transform 0.25s ease;
        z-index: 150;
        background: var(--bg-card);
        border-top: 1px solid var(--border);
      }
      #bottom-panel.open { transform: translateY(0); }
      #stat-strip .stat-item:not(:last-child):not(:nth-last-child(2)) {
        display: none;
      }
    }

    /* ─── Scrollbar ─── */
    * { scrollbar-width: thin; scrollbar-color: var(--border) transparent; }

    /* ─── Pulse animation for Saudi sats ─── */
    @keyframes pulse-glow {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }
  </style>
</head>
<body>

<div id="app">

<!-- ═══ NAVBAR ══════════════════════════════════════════ -->
  <nav id="navbar">
    <button id="hamburger" aria-label="Toggle sidebar">
      <span></span><span></span><span></span>
    </button>

    <a href="#" class="nav-logo">
      <svg width="26" height="26" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Midnight Space logo">
        <circle cx="13" cy="13" r="6" stroke="#00ff88" stroke-width="1.5" fill="none"/>
        <circle cx="13" cy="13" r="11" stroke="#4a9eff" stroke-width="1" stroke-dasharray="3 2" fill="none"/>
        <circle cx="13" cy="2.5" r="2" fill="#00ff88"/>
        <circle cx="20" cy="20" r="1.5" fill="#4a9eff"/>
        <circle cx="4" cy="17" r="1" fill="#ffd700"/>
        <circle cx="13" cy="13" r="2" fill="#00ff88"/>
      </svg>
      <span class="nav-logo-text">Midnight Space — Orbital Tracker</span>
    </a>

    <div id="stat-strip">
      <div class="stat-item">
        <span class="stat-label">Total</span>
        <span class="stat-value" id="stat-total">—</span>
      </div>
      <div class="stat-item">
        <span class="stat-label">Active</span>
        <span class="stat-value" id="stat-active">—</span>
      </div>
      <div class="stat-item">
        <span class="stat-label">Debris</span>
        <span class="stat-value" id="stat-debris">—</span>
      </div>
      <div class="stat-item">
        <span class="stat-label">🇸🇦 Saudi</span>
        <span class="stat-value green" id="stat-saudi">—</span>
      </div>
      <div id="utc-clock">UTC —:—:—</div>
    </div>
  </nav>

  <!-- ═══ SIDEBAR ═════════════════════════════════════════ -->
  <aside id="sidebar">
    <div class="sidebar-tabs">
      <button class="sidebar-tab active" id="tab-all" onclick="switchTab('all')">All Satellites</button>
      <button class="sidebar-tab saudi-tab" id="tab-saudi" onclick="switchTab('saudi')">🇸🇦 Saudi Assets</button>
    </div>

    <!-- ALL SATELLITES TAB -->
    <div id="panel-all" style="display:flex;flex-direction:column;flex:1;overflow:hidden;">
      <div id="filter-panel">
        <div class="filter-section">
          <div class="filter-title">Object Type</div>
          <div class="pill-group" id="type-filters">
            <span class="pill active" data-type="payload" onclick="toggleFilter('type','payload',this)">🛰️ Payload</span>
            <span class="pill active" data-type="debris" onclick="toggleFilter('type','debris',this)">🗑️ Debris</span>
            <span class="pill active" data-type="rocket_body" onclick="toggleFilter('type','rocket_body',this)">🚀 Rocket Body</span>
            <span class="pill active" data-type="unknown" onclick="toggleFilter('type','unknown',this)">❓ Unknown</span>
          </div>
        </div>

        <div class="filter-section">
          <div class="filter-title">Orbit</div>
          <div class="pill-group" id="orbit-filters">
            <span class="pill active" data-orbit="LEO" onclick="toggleFilter('orbit','LEO',this)">LEO</span>
