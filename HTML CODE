// CESIUM INIT
// ═══════════════════════════════════════════════════════════════════
function initCesium() {
  try {
    // Use a valid public Cesium Ion token for world imagery
    // NOTE: Replace with your own free token from cesium.com/ion for full resolution
    Cesium.Ion.defaultAccessToken = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJqdGkiOiJlYWE1OWUxNy1mMWZiLTQzYjYtYTQ4MC1kMDQzNDQ5ZjY5NGMiLCJpZCI6MjU5LCJpYXQiOjE1MTgxNzI0MTV9.GUu-YQTK_BxrMosgScSoJ7JcRUmhZuGGrJzJmXEsVA0';

    // Build layered imagery: Natural Earth II base + coastlines overlay
    // This works 100% offline/without Ion token and looks great
    const naturalEarth = new Cesium.TileMapServiceImageryProvider({
      url: Cesium.buildModuleUrl('Assets/Textures/NaturalEarthII'),
      maximumLevel: 5,
      credit: 'Natural Earth II'
    });

    viewer = new Cesium.Viewer('cesiumContainer', {
      imageryProvider: false,  // we'll add layers manually below
      baseLayerPicker: false,
      geocoder: false,
      homeButton: false,
      sceneModePicker: false,
      navigationHelpButton: false,
      animation: false,
      timeline: false,
      fullscreenButton: false,
      vrButton: false,
      infoBox: false,
      selectionIndicator: false,
      creditContainer: document.createElement('div')
    });

    // Layer 1: Natural Earth II — always available, no internet needed
    // Boost brightness so night-side Earth is still visible
    const neLayer = viewer.imageryLayers.addImageryProvider(naturalEarth);
    neLayer.brightness  = 2.2;   // pump it bright so nightside shows
    neLayer.contrast    = 1.1;
    neLayer.saturation  = 1.3;

    // Layer 2: Try Ion world imagery (Bing satellite) — best quality
    try {
      const ionImagery = Cesium.createWorldImagery({
        style: Cesium.IonWorldImageryStyle.AERIAL_WITH_LABELS
      });
      const ionLayer = viewer.imageryLayers.addImageryProvider(ionImagery);
      ionLayer.alpha = 0.0;
      setTimeout(() => { ionLayer.alpha = 1.0; }, 2500);
    } catch(e) { /* silently keep NaturalEarth */ }

    // ── Also try OSM as a middle-quality free fallback ────────────────
    // OpenStreetMap tiles — free, no token needed, good quality
    try {
      const osm = new Cesium.UrlTemplateImageryProvider({
        url: 'https://tile.openstreetmap.org/{z}/{x}/{y}.png',
        maximumLevel: 18,
        credit: 'OpenStreetMap contributors'
      });
      const osmLayer = viewer.imageryLayers.addImageryProvider(osm);
      osmLayer.alpha = 0.0;
      // Fade in OSM layer once tiles start loading
      setTimeout(() => {
        osmLayer.alpha      = 0.88;
        osmLayer.brightness = 0.75;
        osmLayer.contrast   = 1.15;
        osmLayer.saturation = 0.85;
      }, 2000);
    } catch(e) { /* keep NaturalEarth */ }

    // ── Atmosphere & lighting ─────────────────────────────────────────
    viewer.scene.backgroundColor = Cesium.Color.fromCssColorString('#000005');

    // Real sun-based lighting — day/night terminator visible
    // Keep lighting ON for realism; NaturalEarth base is always visible
    viewer.scene.globe.enableLighting = true;
    viewer.scene.globe.nightFadeOutDistance  = 1.0e7;
    viewer.scene.globe.nightFadeInDistance   = 5.0e7;
    // Reduce contrast of night side so land is still visible
    viewer.scene.globe.atmosphereLightIntensity = 15.0;
    viewer.scene.globe.atmosphereRayleighCoefficient = new Cesium.Cartesian3(5.5e-6, 13.0e-6, 28.4e-6);

    // Deep ocean colour base
    viewer.scene.globe.baseColor = Cesium.Color.fromCssColorString('#0d2444');

    // Atmosphere glow — the blue limb visible from orbit
    viewer.scene.skyAtmosphere.show = true;
    viewer.scene.skyAtmosphere.atmosphereLightIntensity = 20.0;
    viewer.scene.skyAtmosphere.atmosphereRayleighCoefficient = new Cesium.Cartesian3(5.5e-6, 13.0e-6, 28.4e-6);
    viewer.scene.skyAtmosphere.atmosphereMieCoefficient = new Cesium.Cartesian3(21e-6, 21e-6, 21e-6);

    // Star-field skybox
    viewer.scene.skyBox.show = true;
    viewer.scene.sun.show = true;
    viewer.scene.sun.glowFactor = 2.0;
    viewer.scene.moon.show = true;

    // Fog — subtle depth cue
    viewer.scene.fog.enabled = true;
    viewer.scene.fog.density = 0.00012;
    viewer.scene.fog.minimumBrightness = 0.03;

    // Depth test against terrain so satellites above ground render correctly
    viewer.scene.globe.depthTestAgainstTerrain = false;

    // Anti-aliasing
    viewer.scene.postProcessStages.fxaa.enabled = true;

    // Camera start: view centered over Middle East / Saudi Arabia
    viewer.camera.setView({
      destination: Cesium.Cartesian3.fromDegrees(45.0, 24.0, 16000000),
      orientation: {
        heading: Cesium.Math.toRadians(0),
        pitch:   Cesium.Math.toRadians(-35),
        roll:    0
      }
    });

    // ── Bloom / glow post-process ─────────────────────────────────────
    // Makes satellite points appear to glow
    const bloom = viewer.scene.postProcessStages.bloom;
    if (bloom) {
      bloom.enabled = true;
      bloom.uniforms.glowOnly      = false;
      bloom.uniforms.contrast      = 128;
      bloom.uniforms.brightness    = -0.3;
      bloom.uniforms.delta         = 1.0;
      bloom.uniforms.sigma         = 3.78;
      bloom.uniforms.stepSize      = 5.0;
    }

    // ── Click / hover handlers ────────────────────────────────────────
    const handler = new Cesium.ScreenSpaceEventHandler(viewer.scene.canvas);
    handler.setInputAction(onGlobeClick, Cesium.ScreenSpaceEventType.LEFT_CLICK);
    handler.setInputAction(onGlobeHover, Cesium.ScreenSpaceEventType.MOUSE_MOVE);

    return true;
  } catch(e) {
    console.error('CesiumJS init error:', e);
    document.getElementById('cesium-fallback').style.display = 'flex';
    return false;
  }
}

// ═══════════════════════════════════════════════════════════════════
// ORBITAL MECHANICS
// ═══════════════════════════════════════════════════════════════════
function propagateSat(sat, date) {
  try {
    const satrec = satellite.twoline2satrec(sat.line1, sat.line2);
    const posVel = satellite.propagate(satrec, date);
    if (!posVel || !posVel.position) return null;
    const gmst = satellite.gstime(date);
    const geo = satellite.eciToGeodetic(posVel.position, gmst);
    return {
      lat: satellite.degreesLat(geo.latitude),
      lon: satellite.degreesLong(geo.longitude),
      alt: geo.height,   // km
      velocity: posVel.velocity ? Math.sqrt(
        posVel.velocity.x**2 + posVel.velocity.y**2 + posVel.velocity.z**2
      ) : null,
      satrec
    };
  } catch(e) { return null; }
}

function getOrbitalPeriod(sat) {
  try {
    const satrec = satellite.twoline2satrec(sat.line1, sat.line2);
    return 1440 / satrec.no; // minutes; no is in rad/min, 1 rev = 2π rad
  } catch(e) { return null; }
}

function getInclination(sat) {
  try {
    const satrec = satellite.twoline2satrec(sat.line1, sat.line2);
    return (satrec.inclo * 180 / Math.PI).toFixed(2);
  } catch(e) { return null; }
}

function computeOrbitTrail(sat, date) {
  try {
    const satrec = satellite.twoline2satrec(sat.line1, sat.line2);
    const period = 1440 / satrec.no; // minutes per orbit
    const duration = Math.min(period, 90); // up to 90 min
    const steps = 120;
    const positions = [];
    for (let i = 0; i <= steps; i++) {
      const t = new Date(date.getTime() + (i / steps) * duration * 60000);
      const posVel = satellite.propagate(satrec, t);
      if (!posVel || !posVel.position) continue;
      const gmst = satellite.gstime(t);
      const geo = satellite.eciToGeodetic(posVel.position, gmst);
      const lat = satellite.degreesLat(geo.latitude);
      const lon = satellite.degreesLong(geo.longitude);
      const alt = geo.height;
      if (isFinite(lat) && isFinite(lon) && isFinite(alt) && alt > 0) {
        positions.push(Cesium.Cartesian3.fromDegrees(lon, lat, alt * 1000));
      }
    }
    return positions;
  } catch(e) { return []; }
}

// ═══════════════════════════════════════════════════════════════════
// GLOBE MARKER MANAGEMENT
// ═══════════════════════════════════════════════════════════════════
function getSatColor(sat) {
  if (sat.isSaudi) return Cesium.Color.fromCssColorString('#00ff88');
  if (sat.isGCC || sat.isArab) return Cesium.Color.fromCssColorString('#ffd700');
  if (sat.objectType === 'debris') return Cesium.Color.fromCssColorString('#ff4455');
  if (sat.objectType === 'rocket_body') return Cesium.Color.fromCssColorString('#ff8c42');
  return Cesium.Color.fromCssColorString('#4a9eff');
}

function getSatPointSize(sat) {
  if (sat.isSaudi && highlightSaudi) return 16;
  if (sat.isSaudi) return 12;
  if (sat.isGCC || sat.isArab) return 10;
  if (sat.objectType === 'debris') return 5;
  if (sat.objectType === 'rocket_body') return 6;
  return 8;
}

// Returns pixel scale for the outer halo ring
function getSatHaloSize(sat) {
  if (sat.isSaudi && highlightSaudi) return 32;
  if (sat.isSaudi) return 26;
  if (sat.isGCC || sat.isArab) return 22;
  if (sat.objectType === 'debris') return 12;
  if (sat.objectType === 'rocket_body') return 14;
  return 18;
}

// Returns hex string for CSS use
function getCssColor(sat) {
  if (sat.isSaudi) return '#00ff88';
  if (sat.isGCC || sat.isArab) return '#ffd700';
  if (sat.objectType === 'debris') return '#ff4455';
  if (sat.objectType === 'rocket_body') return '#ff8c42';
  return '#4a9eff';
}

// Draw a glowing dot sprite on a canvas element
function makeGlowSprite(cssColor, coreSize, sat) {
  const isSaudi = sat.isSaudi;
  const isDebris = sat.objectType === 'debris' || sat.objectType === 'rocket_body';
  const totalSize = coreSize * 6 + 4;  // canvas dimensions
  const c = document.createElement('canvas');
  c.width  = totalSize;
  c.height = totalSize;
  const ctx = c.getContext('2d');
  const cx = totalSize / 2;
  const cy = totalSize / 2;

  // Outer diffuse glow (large, very transparent)
  if (!isDebris) {
    const outerGlow = ctx.createRadialGradient(cx, cy, 0, cx, cy, coreSize * 2.8);
    outerGlow.addColorStop(0, hexToRgba(cssColor, isSaudi ? 0.35 : 0.2));
    outerGlow.addColorStop(1, hexToRgba(cssColor, 0));
    ctx.beginPath();
    ctx.arc(cx, cy, coreSize * 2.8, 0, Math.PI * 2);
    ctx.fillStyle = outerGlow;
    ctx.fill();
  }

  // Inner glow halo
  const innerGlow = ctx.createRadialGradient(cx, cy, 0, cx, cy, coreSize * 1.6);
  innerGlow.addColorStop(0,   hexToRgba(cssColor, isSaudi ? 0.8 : 0.5));
  innerGlow.addColorStop(0.5, hexToRgba(cssColor, 0.25));
  innerGlow.addColorStop(1,   hexToRgba(cssColor, 0));
  ctx.beginPath();
  ctx.arc(cx, cy, coreSize * 1.6, 0, Math.PI * 2);
  ctx.fillStyle = innerGlow;
  ctx.fill();

  // Bright core dot
  const coreGrad = ctx.createRadialGradient(cx, cy, 0, cx, cy, coreSize * 0.5);
  coreGrad.addColorStop(0,   '#ffffff');
  coreGrad.addColorStop(0.3, cssColor);
  coreGrad.addColorStop(1,   hexToRgba(cssColor, 0.9));
  ctx.beginPath();
  ctx.arc(cx, cy, coreSize * 0.5, 0, Math.PI * 2);
  ctx.fillStyle = coreGrad;
  ctx.fill();

  // Saudi: add a thin ring
  if (isSaudi) {
    ctx.beginPath();
    ctx.arc(cx, cy, coreSize * 1.1, 0, Math.PI * 2);
    ctx.strokeStyle = hexToRgba(cssColor, 0.6);
    ctx.lineWidth = 1;
    ctx.stroke();
  }

  return c;
}

function hexToRgba(hex, alpha) {
  const r = parseInt(hex.slice(1,3),16);
  const g = parseInt(hex.slice(3,5),16);
  const b = parseInt(hex.slice(5,7),16);
  return `rgba(${r},${g},${b},${alpha})`;
}

function placeAllSatellites(date) {
  if (!viewer) return;
  const indicator = document.getElementById('refresh-indicator');
  indicator.classList.add('updating');
  indicator.textContent = '⟳ Updating…';

  TLE_DATA.forEach(sat => {
    const pos = propagateSat(sat, date);
    if (!pos) return;
    const cartesian = Cesium.Cartesian3.fromDegrees(pos.lon, pos.lat, pos.alt * 1000);

    if (satEntities[sat.noradId]) {
      // Update position only
      satEntities[sat.noradId].position = new Cesium.ConstantPositionProperty(cartesian);
    } else {
      // Create new entity with a canvas-drawn glow sprite
      const cssColor = getCssColor(sat);
      const coreSize = getSatPointSize(sat);
      const canvas = makeGlowSprite(cssColor, coreSize, sat);

      const entity = viewer.entities.add({
        id: sat.noradId,
        position: new Cesium.ConstantPositionProperty(cartesian),
        billboard: {
          image: canvas,
          width:  canvas.width,
          height: canvas.height,
          disableDepthTestDistance: Number.POSITIVE_INFINITY,
          heightReference: Cesium.HeightReference.NONE,
          pixelOffset: new Cesium.Cartesian2(0, 0),
          scaleByDistance: new Cesium.NearFarScalar(1.5e6, 1.5, 5.0e7, 0.5)
        },
        properties: { noradId: sat.noradId, satData: sat }
      });
      satEntities[sat.noradId] = entity;
    }
  });

  const now = new Date();
  indicator.classList.remove('updating');
  indicator.textContent = `Updated ${now.toUTCString().slice(17,25)} UTC`;
}

function updateSatSizes() {
  Object.values(satEntities).forEach(entity => {
    const noradId = entity.properties.noradId.getValue();
    const sat = TLE_DATA.find(s => s.noradId === noradId);
    if (!sat || !entity.billboard) return;
    // Regenerate the canvas sprite with new size
    const canvas = makeGlowSprite(getCssColor(sat), getSatPointSize(sat), sat);
    entity.billboard.image = canvas;
    entity.billboard.width  = canvas.width;
    entity.billboard.height = canvas.height;
  });
}

// ═══════════════════════════════════════════════════════════════════
// SELECTION + INTERACTION
// ═══════════════════════════════════════════════════════════════════
function onGlobeClick(movement) {
  if (!viewer) return;
  const picked = viewer.scene.pick(movement.position);
  if (Cesium.defined(picked) && picked.id) {
    const entity = picked.id;
    const noradId = entity.properties && entity.properties.noradId ? entity.properties.noradId.getValue() : null;
    if (noradId) selectSatellite(noradId, false);
  }
}

let tooltipTimeout = null;
function onGlobeHover(movement) {
  if (!viewer) return;
  const tooltip = document.getElementById('tooltip');
  const picked = viewer.scene.pick(movement.endPosition);
  if (Cesium.defined(picked) && picked.id && picked.id.properties) {
    const noradId = picked.id.properties.noradId ? picked.id.properties.noradId.getValue() : null;
    if (noradId) {
      const sat = TLE_DATA.find(s => s.noradId === noradId);
      if (sat) {
        tooltip.style.display = 'block';
        tooltip.style.left = (movement.endPosition.x + 14) + 'px';
        tooltip.style.top  = (movement.endPosition.y - 10) + 'px';
        tooltip.innerHTML = `<strong>${sat.name}</strong><br><span style="color:var(--text-muted);font-size:10px">${sat.objectType} · ${sat.orbitType}</span>`;
        return;
      }
    }
  }
  tooltip.style.display = 'none';
}

function selectSatellite(noradId, flyTo) {
  // Deselect previous — restore normal sprite
  if (selectedId && satEntities[selectedId]) {
    const prev = TLE_DATA.find(s => s.noradId === selectedId);
    if (prev && satEntities[selectedId].billboard) {
      const prevCanvas = makeGlowSprite(getCssColor(prev), getSatPointSize(prev), prev);
      satEntities[selectedId].billboard.image = prevCanvas;
      satEntities[selectedId].billboard.width  = prevCanvas.width;
      satEntities[selectedId].billboard.height = prevCanvas.height;
      satEntities[selectedId].billboard.scale  = 1.0;
    }
  }

  // Remove old trail
  if (trailEntity) {
    viewer && viewer.entities.remove(trailEntity);
    trailEntity = null;
  }

  selectedId = noradId;
  const sat = TLE_DATA.find(s => s.noradId === noradId);
  if (!sat) return;

  // Highlight selected entity — make it white + larger
  if (viewer && satEntities[noradId]) {
    const selCanvas = makeGlowSprite('#ffffff', getSatPointSize(sat) + 6, sat);
    satEntities[noradId].billboard.image  = selCanvas;
    satEntities[noradId].billboard.width  = selCanvas.width;
    satEntities[noradId].billboard.height = selCanvas.height;
    satEntities[noradId].billboard.scale  = 1.3;

    // Draw orbit trail — dashed glow
    const now = new Date();
    const trail = computeOrbitTrail(sat, now);
    if (trail.length > 2 && viewer) {
      const trailColor = sat.isSaudi
        ? Cesium.Color.fromCssColorString('#00ff88')
        : sat.isArab || sat.isGCC
          ? Cesium.Color.fromCssColorString('#ffd700')
          : sat.objectType === 'debris'
            ? Cesium.Color.fromCssColorString('#ff4455')
            : Cesium.Color.fromCssColorString('#4a9eff');

      trailEntity = viewer.entities.add({
        polyline: {
          positions: trail,
          width: 2.0,
          material: new Cesium.PolylineGlowMaterialProperty({
            glowPower: 0.25,
            taperPower: 0.7,
            color: trailColor.withAlpha(0.85)
          }),
          arcType: Cesium.ArcType.NONE,
          clampToGround: false
        }
      });
    }

    // Fly camera
    if (flyTo !== false) {
      const pos = propagateSat(sat, now);
      if (pos) {
        viewer.camera.flyTo({
          destination: Cesium.Cartesian3.fromDegrees(pos.lon, pos.lat, pos.alt * 1000 + 3000000),
          duration: 1.5
        });
      }
    }
  }

  // Update list highlights
  document.querySelectorAll('.sat-item').forEach(el => {
    el.classList.remove('selected','saudi-sel');
    if (el.dataset.norad === noradId) {
      el.classList.add('selected');
      if (sat.isSaudi) el.classList.add('saudi-sel');
      el.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
    }
  });

  // Show detail card
  showDetailCard(sat);

  // Mobile: open bottom drawer
  if (window.innerWidth <= 768) {
    document.getElementById('bottom-panel').classList.add('open');
  }
}

