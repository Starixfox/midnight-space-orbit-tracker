// ═══════════════════════════════════════════════════════════════════
// UTC CLOCK
// ═══════════════════════════════════════════════════════════════════
function updateClock() {
  const now = new Date();
  const h = String(now.getUTCHours()).padStart(2,'0');
  const m = String(now.getUTCMinutes()).padStart(2,'0');
  const s = String(now.getUTCSeconds()).padStart(2,'0');
  document.getElementById('utc-clock').textContent = `UTC ${h}:${m}:${s}`;
}

// ═══════════════════════════════════════════════════════════════════
// TAB SWITCHER
// ═══════════════════════════════════════════════════════════════════
function switchTab(tab) {
  activeTab = tab;
  const allPanel = document.getElementById('panel-all');
  const saudiPanel = document.getElementById('panel-saudi');
  if (tab === 'all') {
    allPanel.style.display = 'flex';
    allPanel.style.flexDirection = 'column';
    allPanel.style.flex = '1';
    allPanel.style.overflow = 'hidden';
    saudiPanel.style.display = 'none';
  } else {
    allPanel.style.display = 'none';
    saudiPanel.style.display = 'flex';
  }
  document.getElementById('tab-all').classList.toggle('active', tab === 'all');
  document.getElementById('tab-saudi').classList.toggle('active', tab === 'saudi');
  if (tab === 'saudi') renderSaudiPanel();
}

// ═══════════════════════════════════════════════════════════════════
// GLOBE CONTROLS
// ═══════════════════════════════════════════════════════════════════
function globeZoom(dir) {
  if (!viewer) return;
  const cam = viewer.camera;
  const height = cam.positionCartographic.height;
  cam.flyTo({
    destination: Cesium.Cartesian3.fromRadians(
      cam.positionCartographic.longitude,
      cam.positionCartographic.latitude,
      height * (dir > 0 ? 0.5 : 2.0)
    ),
    duration: 0.5
  });
}

function globeReset() {
  if (!viewer) return;
  viewer.camera.flyTo({
    destination: Cesium.Cartesian3.fromDegrees(45.0, 24.0, 16000000),
    orientation: {
      heading: Cesium.Math.toRadians(0),
      pitch:   Cesium.Math.toRadians(-35),
      roll:    0
    },
    duration: 1.5
  });
}

// ═══════════════════════════════════════════════════════════════════
// MOBILE HAMBURGER
// ═══════════════════════════════════════════════════════════════════
document.getElementById('hamburger').addEventListener('click', () => {
  document.getElementById('sidebar').classList.toggle('open');
});

// ═══════════════════════════════════════════════════════════════════
// STARTUP
// ═══════════════════════════════════════════════════════════════════
window.addEventListener('DOMContentLoaded', () => {
  updateStats();
  updateClock();
  setInterval(updateClock, 1000);

  // Init sidebar
  renderSatList();

  // Init Cesium
  const cesiumOk = initCesium();

  if (cesiumOk) {
    const now = new Date();
    placeAllSatellites(now);

    // Refresh every 10 seconds
    setInterval(() => {
      placeAllSatellites(new Date());
    }, 10000);
  } else {
    // Fallback: just show list without globe
    document.getElementById('cesium-fallback').style.display = 'flex';
  }
});
