    viewer.scene.globe.baseColor = Cesium.Color.fromCssColorString('#0a1020');
    viewer.scene.skyBox.show = true;
    viewer.scene.sun.show = true;
    viewer.scene.moon.show = false;

    // Camera start position
    viewer.camera.setView({
      destination: Cesium.Cartesian3.fromDegrees(45.0, 20.0, 18000000)
    });

    // Click handler
    const handler = new Cesium.ScreenSpaceEventHandler(viewer.scene.canvas);
    handler.setInputAction(onGlobeClick, Cesium.ScreenSpaceEventType.LEFT_CLICK);
    handler.setInputAction(onGlobeHover, Cesium.ScreenSpaceEventType.MOUSE_MOVE);

    return true;
  } catch(e) {
    console.error('CesiumJS init error:', e);
    document.getElementById('cesium-fallback').style.display = 'flex';
    return false;
  }
}

// ═══════════════════════════════════════════════════════════════════
// ORBITAL MECHANICS
// ═══════════════════════════════════════════════════════════════════
function propagateSat(sat, date) {
  try {
    const satrec = satellite.twoline2satrec(sat.line1, sat.line2);
    const posVel = satellite.propagate(satrec, date);
    if (!posVel || !posVel.position) return null;
    const gmst = satellite.gstime(date);
    const geo = satellite.eciToGeodetic(posVel.position, gmst);
    return {
      lat: satellite.degreesLat(geo.latitude),
      lon: satellite.degreesLong(geo.longitude),
      alt: geo.height,   // km
      velocity: posVel.velocity ? Math.sqrt(
        posVel.velocity.x**2 + posVel.velocity.y**2 + posVel.velocity.z**2
      ) : null,
      satrec
    };
  } catch(e) { return null; }
}

function getOrbitalPeriod(sat) {
  try {
    const satrec = satellite.twoline2satrec(sat.line1, sat.line2);
    return 1440 / satrec.no; // minutes; no is in rad/min, 1 rev = 2π rad
  } catch(e) { return null; }
}

function getInclination(sat) {
  try {
    const satrec = satellite.twoline2satrec(sat.line1, sat.line2);
    return (satrec.inclo * 180 / Math.PI).toFixed(2);
  } catch(e) { return null; }
}

function computeOrbitTrail(sat, date) {
  try {
    const satrec = satellite.twoline2satrec(sat.line1, sat.line2);
    const period = 1440 / satrec.no; // minutes per orbit
    const duration = Math.min(period, 90); // up to 90 min
    const steps = 120;
    const positions = [];
    for (let i = 0; i <= steps; i++) {
      const t = new Date(date.getTime() + (i / steps) * duration * 60000);
      const posVel = satellite.propagate(satrec, t);
      if (!posVel || !posVel.position) continue;
      const gmst = satellite.gstime(t);
      const geo = satellite.eciToGeodetic(posVel.position, gmst);
      const lat = satellite.degreesLat(geo.latitude);
      const lon = satellite.degreesLong(geo.longitude);
      const alt = geo.height;
      if (isFinite(lat) && isFinite(lon) && isFinite(alt) && alt > 0) {
        positions.push(Cesium.Cartesian3.fromDegrees(lon, lat, alt * 1000));
      }
    }
    return positions;
  } catch(e) { return []; }
}

// ═══════════════════════════════════════════════════════════════════
// GLOBE MARKER MANAGEMENT
// ═══════════════════════════════════════════════════════════════════
function getSatColor(sat) {
  if (sat.isSaudi) return Cesium.Color.fromCssColorString('#00ff88');
  if (sat.isGCC || sat.isArab) return Cesium.Color.fromCssColorString('#ffd700');
  if (sat.objectType === 'debris') return Cesium.Color.fromCssColorString('#ff4455');
  if (sat.objectType === 'rocket_body') return Cesium.Color.fromCssColorString('#ff8c42');
  return Cesium.Color.fromCssColorString('#4a9eff');
}

function getSatPointSize(sat) {
  if (sat.isSaudi && highlightSaudi) return 14;
  if (sat.isSaudi) return 10;
  if (sat.isGCC || sat.isArab) return 8;
  if (sat.objectType === 'debris') return 5;
  if (sat.objectType === 'rocket_body') return 6;
  return 7;
}

function placeAllSatellites(date) {
  if (!viewer) return;
  const indicator = document.getElementById('refresh-indicator');
  indicator.classList.add('updating');
  indicator.textContent = '⟳ Updating…';

  TLE_DATA.forEach(sat => {
    const pos = propagateSat(sat, date);
    if (!pos) return;
    const cartesian = Cesium.Cartesian3.fromDegrees(pos.lon, pos.lat, pos.alt * 1000);

    if (satEntities[sat.noradId]) {
      // Update position
      satEntities[sat.noradId].position = new Cesium.ConstantPositionProperty(cartesian);
    } else {
      // Create new entity
      const color = getSatColor(sat);
      const size = getSatPointSize(sat);
      const entity = viewer.entities.add({
        id: sat.noradId,
        position: new Cesium.ConstantPositionProperty(cartesian),
        point: {
          pixelSize: size,
          color: color,
          outlineColor: sat.isSaudi ? Cesium.Color.fromCssColorString('#ffffff').withAlpha(0.4) : Cesium.Color.TRANSPARENT,
          outlineWidth: sat.isSaudi ? 1.5 : 0,
          disableDepthTestDistance: Number.POSITIVE_INFINITY,
          heightReference: Cesium.HeightReference.NONE
        },
        label: {
          text: '',  // no labels by default
          show: false
        },
        properties: { noradId: sat.noradId, satData: sat }
      });
      satEntities[sat.noradId] = entity;
    }
  });

  const now = new Date();
  indicator.classList.remove('updating');
  indicator.textContent = `Updated ${now.toUTCString().slice(17,25)} UTC`;
}

function updateSatSizes() {
  Object.values(satEntities).forEach(entity => {
    const noradId = entity.properties.noradId.getValue();
    const sat = TLE_DATA.find(s => s.noradId === noradId);
    if (!sat) return;
    entity.point.pixelSize = new Cesium.ConstantProperty(getSatPointSize(sat));
  });
}

// ═══════════════════════════════════════════════════════════════════
// SELECTION + INTERACTION
// ═══════════════════════════════════════════════════════════════════
function onGlobeClick(movement) {
  if (!viewer) return;
  const picked = viewer.scene.pick(movement.position);
  if (Cesium.defined(picked) && picked.id) {
    const entity = picked.id;
    const noradId = entity.properties && entity.properties.noradId ? entity.properties.noradId.getValue() : null;
    if (noradId) selectSatellite(noradId, false);
  }
}

let tooltipTimeout = null;
function onGlobeHover(movement) {
  if (!viewer) return;
  const tooltip = document.getElementById('tooltip');
  const picked = viewer.scene.pick(movement.endPosition);
  if (Cesium.defined(picked) && picked.id && picked.id.properties) {
    const noradId = picked.id.properties.noradId ? picked.id.properties.noradId.getValue() : null;
    if (noradId) {
      const sat = TLE_DATA.find(s => s.noradId === noradId);
      if (sat) {
        tooltip.style.display = 'block';
        tooltip.style.left = (movement.endPosition.x + 14) + 'px';
        tooltip.style.top  = (movement.endPosition.y - 10) + 'px';
        tooltip.innerHTML = `<strong>${sat.name}</strong><br><span style="color:var(--text-muted);font-size:10px">${sat.objectType} · ${sat.orbitType}</span>`;
        return;
      }
    }
  }
  tooltip.style.display = 'none';
}

function selectSatellite(noradId, flyTo) {
  // Deselect previous
  if (selectedId && satEntities[selectedId]) {
    const prev = TLE_DATA.find(s => s.noradId === selectedId);
    if (prev) {
      satEntities[selectedId].point.color = getSatColor(prev);
    }
  }

  // Remove old trail
  if (trailEntity) {
    viewer && viewer.entities.remove(trailEntity);
    trailEntity = null;
  }

  selectedId = noradId;
  const sat = TLE_DATA.find(s => s.noradId === noradId);
  if (!sat) return;

  // Highlight selected entity
  if (viewer && satEntities[noradId]) {
    satEntities[noradId].point.color = Cesium.Color.WHITE;
    satEntities[noradId].point.pixelSize = new Cesium.ConstantProperty(14);

    // Draw orbit trail
    const now = new Date();
    const trail = computeOrbitTrail(sat, now);
    if (trail.length > 2 && viewer) {
      trailEntity = viewer.entities.add({
        polyline: {
          positions: trail,
          width: 1.5,
          material: new Cesium.PolylineGlowMaterialProperty({
            glowPower: 0.15,
            color: sat.isSaudi
              ? Cesium.Color.fromCssColorString('#00ff88').withAlpha(0.7)
              : Cesium.Color.fromCssColorString('#4a9eff').withAlpha(0.6)
          }),
          clampToGround: false
        }
      });
    }

    // Fly camera
    if (flyTo !== false) {
      const pos = propagateSat(sat, now);
      if (pos) {
        viewer.camera.flyTo({
          destination: Cesium.Cartesian3.fromDegrees(pos.lon, pos.lat, pos.alt * 1000 + 3000000),
          duration: 1.5
        });
      }
    }
  }

  // Update list highlights
  document.querySelectorAll('.sat-item').forEach(el => {
    el.classList.remove('selected','saudi-sel');
    if (el.dataset.norad === noradId) {
      el.classList.add('selected');
      if (sat.isSaudi) el.classList.add('saudi-sel');
      el.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
    }
  });

  // Show detail card
  showDetailCard(sat);

  // Mobile: open bottom drawer
  if (window.innerWidth <= 768) {
    document.getElementById('bottom-panel').classList.add('open');
  }
}

// ═══════════════════════════════════════════════════════════════════
// DETAIL CARD
// ═══════════════════════════════════════════════════════════════════
function showDetailCard(sat) {
  document.getElementById('detail-empty').style.display = 'none';
  const card = document.getElementById('detail-card');
  card.style.display = 'block';

  const now = new Date();
  const pos = propagateSat(sat, now);
  const period = getOrbitalPeriod(sat);
  const incl = getInclination(sat);

  const lat  = pos ? pos.lat.toFixed(3) : 'N/A';
  const lon  = pos ? pos.lon.toFixed(3) : 'N/A';
  const alt  = pos ? pos.alt.toFixed(1) + ' km' : 'N/A';
  const vel  = pos && pos.velocity ? pos.velocity.toFixed(3) + ' km/s' : 'N/A';
  const per  = period ? period.toFixed(2) + ' min' : 'N/A';

  const orbitBadge = `<span class="badge badge-${sat.orbitType.toLowerCase()}">${sat.orbitType}</span>`;
  const typeBadge = `<span class="badge ${sat.objectType === 'debris' ? 'badge-debris' : sat.objectType === 'rocket_body' ? 'badge-rocket' : 'badge-payload'}">${sat.objectType.replace('_',' ')}</span>`;
  const saudiFlag = sat.isSaudi ? ' 🇸🇦' : '';

  card.innerHTML = `
    <div class="detail-header">
      <div>
        <div class="detail-name ${sat.isSaudi ? 'saudi' : ''}">${sat.name}${saudiFlag}</div>
        <div class="detail-norad">NORAD ID: ${sat.noradId} &nbsp;|&nbsp; ${sat.country} &nbsp;|&nbsp; ${sat.operator}</div>
      </div>
      <div style="display:flex;gap:6px;align-items:center;margin-left:auto;flex-shrink:0">
        ${orbitBadge} ${typeBadge}
      </div>
    </div>
    <div class="detail-grid">
      <div class="detail-cell">
        <div class="detail-cell-label">Latitude</div>
        <div class="detail-cell-value blue">${lat}°</div>
      </div>
      <div class="detail-cell">
        <div class="detail-cell-label">Longitude</div>
        <div class="detail-cell-value blue">${lon}°</div>
      </div>
      <div class="detail-cell">
        <div class="detail-cell-label">Altitude</div>
        <div class="detail-cell-value ${sat.isSaudi ? 'green' : 'blue'}">${alt}</div>
      </div>
      <div class="detail-cell">
        <div class="detail-cell-label">Velocity</div>
        <div class="detail-cell-value">${vel}</div>
      </div>
      <div class="detail-cell">
        <div class="detail-cell-label">Period</div>
        <div class="detail-cell-value">${per}</div>
      </div>
      <div class="detail-cell">
        <div class="detail-cell-label">Inclination</div>
        <div class="detail-cell-value">${incl !== null ? incl + '°' : 'N/A'}</div>
      </div>
      <div class="detail-cell">
        <div class="detail-cell-label">Launch Year</div>
        <div class="detail-cell-value">${sat.launchYear}</div>
      </div>
      <div class="detail-cell">
        <div class="detail-cell-label">Orbit Type</div>
        <div class="detail-cell-value">${sat.orbitType}</div>
      </div>
    </div>
    <div class="detail-desc">${sat.description}</div>
    <a class="detail-link" href="https://www.space-track.org/basicspacedata/query/class/gp/NORAD_CAT_ID/${sat.noradId}" target="_blank" rel="noopener">
      ↗ View on Space-Track.org
    </a>
  `;
}

// ═══════════════════════════════════════════════════════════════════
// SIDEBAR LIST
// ═══════════════════════════════════════════════════════════════════
function getFilteredSats() {
  const search = document.getElementById('search-input').value.toLowerCase().trim();
  return TLE_DATA.filter(sat => {
    if (!filters.types.has(sat.objectType)) return false;
    if (!filters.orbits.has(sat.orbitType)) return false;
    if (filters.region === 'saudi' && !sat.isSaudi) return false;
    if (filters.region === 'arab' && !sat.isArab) return false;
    if (filters.region === 'gcc' && !sat.isGCC) return false;
    if (filters.region === 'global' && (sat.isArab || sat.isGCC)) return false;
    if (search && !sat.name.toLowerCase().includes(search) && !sat.noradId.includes(search)) return false;
    return true;
  });
}

function getTypeIcon(sat) {
  if (sat.objectType === 'debris') return '🗑️';
  if (sat.objectType === 'rocket_body') return '🚀';
  if (sat.objectType === 'unknown') return '❓';
  return '🛰️';
}

function renderSatList() {
  const list = document.getElementById('sat-list');
  const sats = getFilteredSats();

  list.innerHTML = sats.map(sat => `
    <div class="sat-item ${selectedId === sat.noradId ? 'selected' + (sat.isSaudi ? ' saudi-sel' : '') : ''}"
         data-norad="${sat.noradId}"
         onclick="selectSatellite('${sat.noradId}', true)">
      <span class="sat-icon">${getTypeIcon(sat)}</span>
      <div class="sat-info">
        <div class="sat-name ${sat.isSaudi ? 'saudi-name' : ''}">${sat.name}</div>
        <div class="sat-meta">
          <span class="badge badge-${sat.orbitType.toLowerCase()}">${sat.orbitType}</span>
          <span class="badge ${sat.objectType === 'debris' ? 'badge-debris' : sat.objectType === 'rocket_body' ? 'badge-rocket' : 'badge-payload'}">${sat.objectType.replace('_',' ')}</span>
          ${sat.isSaudi ? '<span class="saudi-flag">🇸🇦</span>' : ''}
        </div>
      </div>
    </div>
  `).join('');

  // Show/hide markers based on filters
  if (viewer) {
    const filteredIds = new Set(sats.map(s => s.noradId));
    Object.entries(satEntities).forEach(([id, entity]) => {
      entity.show = filteredIds.has(id);
    });
  }
}

// ═══════════════════════════════════════════════════════════════════
// FILTER CONTROLS
// ═══════════════════════════════════════════════════════════════════
function toggleFilter(category, value, el) {
  if (category === 'type') {
    if (filters.types.has(value)) {
      if (filters.types.size > 1) { filters.types.delete(value); el.classList.remove('active'); }
    } else {
      filters.types.add(value); el.classList.add('active');
    }
  } else if (category === 'orbit') {
    if (filters.orbits.has(value)) {
      if (filters.orbits.size > 1) { filters.orbits.delete(value); el.classList.remove('active'); }
    } else {
      filters.orbits.add(value); el.classList.add('active');
    }
  }
  applyFilters();
}

function setRegion(value, el) {
  filters.region = value;
  document.querySelectorAll('#region-filters .pill').forEach(p => p.classList.remove('active','green-pill'));
  el.classList.add('active');
  if (value === 'all') el.classList.add('green-pill');
  applyFilters();
}

function applyFilters() {
  renderSatList();
}

function toggleHighlight() {
  highlightSaudi = !highlightSaudi;
  document.getElementById('highlight-track').classList.toggle('on', highlightSaudi);
  updateSatSizes();
}

// ═══════════════════════════════════════════════════════════════════
// SAUDI ASSETS TAB
// ═══════════════════════════════════════════════════════════════════
function renderSaudiPanel() {
  const saudiSats = TLE_DATA.filter(s => s.isSaudi);
  const active = saudiSats.filter(s => s.objectType === 'payload').length;
  const geo = saudiSats.filter(s => s.orbitType === 'GEO').length;
  const leo = saudiSats.filter(s => s.orbitType === 'LEO').length;

  document.getElementById('saudi-total').textContent = saudiSats.length;
  document.getElementById('saudi-active').textContent = active;
  document.getElementById('saudi-geo').textContent = geo;
  document.getElementById('saudi-leo').textContent = leo;

  document.getElementById('saudi-desc-text').textContent =
    `Saudi Arabia currently operates ${active} active tracked satellites and space objects in this dataset. ` +
    `The Kingdom has ${geo} spacecraft in geostationary orbit and ${leo} in low Earth orbit, reflecting its ambitious Vision 2030 space programme goals.`;

  const listEl = document.getElementById('saudi-sat-list');
  listEl.innerHTML = saudiSats.map(sat => `
    <div class="sat-item ${selectedId === sat.noradId ? 'selected saudi-sel' : ''}"
         data-norad="${sat.noradId}"
         onclick="selectSatellite('${sat.noradId}', true)">
      <span class="sat-icon">${getTypeIcon(sat)}</span>
      <div class="sat-info">
        <div class="sat-name saudi-name">${sat.name} 🇸🇦</div>
        <div class="sat-meta">
          <span class="badge badge-${sat.orbitType.toLowerCase()}">${sat.orbitType}</span>
          <span class="badge badge-payload">${sat.objectType}</span>
          <span style="font-size:10px;color:var(--text-muted)">${sat.operator}</span>
        </div>
      </div>
    </div>
  `).join('');
}

// ═══════════════════════════════════════════════════════════════════
// STATS BAR
// ═══════════════════════════════════════════════════════════════════
function updateStats() {
  const total = TLE_DATA.length;
  const active = TLE_DATA.filter(s => s.objectType === 'payload').length;
  const debris = TLE_DATA.filter(s => s.objectType === 'debris' || s.objectType === 'rocket_body').length;
  const saudi = TLE_DATA.filter(s => s.isSaudi).length;

  document.getElementById('stat-total').textContent = total;
  document.getElementById('stat-active').textContent = active;
  document.getElementById('stat-debris').textContent = debris;
  document.getElementById('stat-saudi').textContent = saudi;
}

// ═══════════════════════════════════════════════════════════════════
// UTC CLOCK
// ═══════════════════════════════════════════════════════════════════
function updateClock() {
  const now = new Date();
  const h = String(now.getUTCHours()).padStart(2,'0');
  const m = String(now.getUTCMinutes()).padStart(2,'0');
  const s = String(now.getUTCSeconds()).padStart(2,'0');
  document.getElementById('utc-clock').textContent = `UTC ${h}:${m}:${s}`;
}

// ═══════════════════════════════════════════════════════════════════
// TAB SWITCHER
// ═══════════════════════════════════════════════════════════════════
function switchTab(tab) {
  activeTab = tab;
  const allPanel = document.getElementById('panel-all');
  const saudiPanel = document.getElementById('panel-saudi');
  if (tab === 'all') {
    allPanel.style.display = 'flex';
    allPanel.style.flexDirection = 'column';
    allPanel.style.flex = '1';
    allPanel.style.overflow = 'hidden';
    saudiPanel.style.display = 'none';
  } else {
    allPanel.style.display = 'none';
    saudiPanel.style.display = 'flex';
  }
  document.getElementById('tab-all').classList.toggle('active', tab === 'all');
  document.getElementById('tab-saudi').classList.toggle('active', tab === 'saudi');
  if (tab === 'saudi') renderSaudiPanel();
}

// ═══════════════════════════════════════════════════════════════════
// GLOBE CONTROLS
// ═══════════════════════════════════════════════════════════════════
function globeZoom(dir) {
  if (!viewer) return;
  const cam = viewer.camera;
  const height = cam.positionCartographic.height;
  cam.flyTo({
    destination: Cesium.Cartesian3.fromRadians(
      cam.positionCartographic.longitude,
      cam.positionCartographic.latitude,
      height * (dir > 0 ? 0.5 : 2.0)
    ),
    duration: 0.5
  });
}

function globeReset() {
  if (!viewer) return;
  viewer.camera.flyTo({
    destination: Cesium.Cartesian3.fromDegrees(45.0, 20.0, 18000000),
    duration: 1.5
  });
}

// ═══════════════════════════════════════════════════════════════════
// MOBILE HAMBURGER
// ═══════════════════════════════════════════════════════════════════
document.getElementById('hamburger').addEventListener('click', () => {
  document.getElementById('sidebar').classList.toggle('open');
});

// ═══════════════════════════════════════════════════════════════════
// STARTUP
// ═══════════════════════════════════════════════════════════════════
window.addEventListener('DOMContentLoaded', () => {
  updateStats();
  updateClock();
  setInterval(updateClock, 1000);

  // Init sidebar
  renderSatList();

  // Init Cesium
  const cesiumOk = initCesium();

  if (cesiumOk) {
    const now = new Date();
    placeAllSatellites(now);

    // Refresh every 10 seconds
    setInterval(() => {
      placeAllSatellites(new Date());
    }, 10000);
  } else {
    // Fallback: just show list without globe
    document.getElementById('cesium-fallback').style.display = 'flex';
  }
});
